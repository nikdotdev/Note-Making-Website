<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title><%= filename %></title>
</head>
<body class="bg-gradient-to-b from-zinc-900 to-black min-h-screen text-zinc-200">

  <div class="max-w-3xl mx-auto px-4 py-10">

    <a href="/" 
       class="text-blue-400 hover:text-blue-300 transition tracking-tight text-sm inline-flex items-center mb-6">
      ← Back to Home
    </a>

    <div class="bg-zinc-800/40 rounded-2xl p-8 shadow-lg backdrop-blur-md border border-zinc-700/40">
      <h1 class="text-3xl font-semibold tracking-tight text-white mb-3">
        <%= filename %>
      </h1>

      <p class="text-zinc-300 leading-relaxed text-lg">
        <%= desc %>
      </p>
    </div>

  </div>

</body>
</html>
